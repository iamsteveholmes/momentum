{
  "description": "Default protected path patterns for Momentum file-protection hook",
  "paths": [
    {
      "pattern": "tests/acceptance/*",
      "policy": "acceptance-test-dir",
      "reason": "modify via sprint-planning only"
    },
    {
      "pattern": "*.feature",
      "policy": "acceptance-test-dir",
      "reason": "modify via sprint-planning only"
    },
    {
      "pattern": ".claude/rules/*",
      "policy": "project-rules",
      "reason": "project rules are read-only during implementation"
    },
    {
      "pattern": "_bmad-output/planning-artifacts/*.md",
      "policy": "planning-artifacts",
      "reason": "modify via refine workflow only"
    },
    {
      "pattern": ".momentum/stories/index.json",
      "policy": "index-files",
      "reason": "index files are managed by sprint-manager only"
    },
    {
      "pattern": ".momentum/sprints/index.json",
      "policy": "index-files",
      "reason": "index files are managed by sprint-manager only"
    },
    {
      "pattern": ".momentum/sprints/*/specs/*",
      "policy": "sprint-specs",
      "reason": "frozen at sprint activation — modify via sprint-planning only"
    },
    {
      "pattern": ".momentum/sprints/*/coverage-plan.md",
      "policy": "sprint-coverage-plan",
      "reason": "frozen at sprint activation — modify via sprint-planning only"
    },
    {
      "pattern": "momentum/verification-harness.json",
      "policy": "verification-harness",
      "reason": "root harness is managed by agent-builder and plugin install only"
    }
  ]
}
