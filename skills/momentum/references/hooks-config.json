{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/momentum/hooks/lint-format.sh \"$CLAUDE_TOOL_INPUT_FILE_PATH\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/momentum/hooks/file-protection.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[momentum-gate] ✓ checked stop conditions — quality gate placeholder (Story 3.3 implements)'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
