{
  "description": "Default protected path patterns for Momentum file-protection hook",
  "paths": [
    {
      "pattern": "tests/acceptance/*",
      "policy": "acceptance-test-dir",
      "reason": "modify via sprint-planning only"
    },
    {
      "pattern": "*.feature",
      "policy": "acceptance-test-dir",
      "reason": "modify via sprint-planning only"
    },
    {
      "pattern": ".claude/rules/*",
      "policy": "project-rules",
      "reason": "project rules are read-only during implementation"
    },
    {
      "pattern": "_bmad-output/planning-artifacts/*.md",
      "policy": "planning-artifacts",
      "reason": "modify via refine workflow only"
    },
    {
      "pattern": "_bmad-output/implementation-artifacts/stories/index.json",
      "policy": "index-files",
      "reason": "index files are managed by sprint-manager only"
    },
    {
      "pattern": "_bmad-output/implementation-artifacts/sprints/index.json",
      "policy": "index-files",
      "reason": "index files are managed by sprint-manager only"
    }
  ]
}
